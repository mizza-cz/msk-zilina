<section class="fanshopSlider">
  <div class="container">
    <div class="fanshopSlider__inner swiper">
      <div
        class="d-flex align-items-center justify-content-between mb-5 flex-wrap gap-4"
      >
        <h4 class="h1 text-black-primary">Fanshop</h4>

        <div class="d-flex align-items-center">
          <a href="#" class="button-stroke text-black-primary"
            >Prejsť do fanshopu</a
          >
          <div class="d-flex align-items-center me-1">
            <button class="swipe-prev" type="button" aria-label="Previous">
              {% include "@images/chevron-down.svg" %}
            </button>
            <button class="swipe-next" type="button" aria-label="Next">
              {% include "@images/chevron-down.svg" %}
            </button>
          </div>
        </div>
      </div>

      <ul role="list" class="swiper-wrapper">
        {% for i in 1..3 %}
        <li class="swiper-slide normal">
          <a href="#" class="fanshopSlider-item">
            <img
              class="fanshopSlider-item__img"
              src="images/content/product.png"
              loading="lazy"
              alt="product"
            />
            <div class="fanshopSlider-item__content">
              Pánska mikina Nike x MŠK Žilina žltá
            </div>
          </a>
        </li>
        <li class="swiper-slide small">
          <a href="#" class="fanshopSlider-item">
            <img
              class="fanshopSlider-item__img"
              src="images/content/product.png"
              loading="lazy"
              alt="product"
            />
            <div class="fanshopSlider-item__content">
              Pánska mikina Nike x MŠK Žilina žltá
            </div>
          </a>
        </li>
        <li class="swiper-slide big">
          <a href="#" class="fanshopSlider-item">
            <img
              class="fanshopSlider-item__img"
              src="images/content/product.png"
              loading="lazy"
              alt="product"
            />
            <div class="fanshopSlider-item__content">
              Pánska mikina Nike x MŠK Žilina žltá
            </div>
          </a>
        </li>

        {% endfor %}
      </ul>
    </div>
  </div>
</section>

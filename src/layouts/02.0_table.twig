{% extends "@components/base/base.twig" %} {% set title = "02.0_table" %} {%
block main %} {% include "@components/header/header.twig" %}
<main class="main" aria-label="Hlavní obsah">
  <div
    class="headerPage"
    style="background-image: url('images/content/bg-page.png')"
  >
    <div class="container">
      <div class="headerPage__inner">
        <div class="headerPage__content">
          <details class="headerPage__dropdown mb-md-8 mb-6">
            <summary class="d-flex gap-md-6 gap-4 align-items-center">
              <h1 class="h1 text-white-primary mb-0">Tabuľka</h1>
              <span class="iconLink">
                {% include "@images/chevron-down.svg" %}
              </span>
            </summary>

            <ul class="headerPage__dropdown-list">
              <li><a href="#">Súpiska</a></li>
              <li><a href="#">Realizačný tím</a></li>
              <li><a href="#">Zápasy </a></li>
              <li><a class="active" href="#">Tabuľka </a></li>
              <li><a href="#">Štatistiky </a></li>
            </ul>
          </details>

          <div
            class="d-flex align-items-center gap-4 justify-content-between flex-wrap"
          >
            <nav class="nav headerPage-tabs" id="nav-tab" role="tablist">
              <button
                class="headerPage-tabs__btn active"
                id="nav-ateam-tab"
                data-bs-toggle="tab"
                data-bs-target="#nav-ateam"
                type="button"
                role="tab"
                aria-controls="nav-ateam"
                aria-selected="true"
              >
                A-Tím
              </button>
              <button
                class="headerPage-tabs__btn"
                id="nav-bteam-tab"
                data-bs-toggle="tab"
                data-bs-target="#nav-bteam"
                type="button"
                role="tab"
                aria-controls="nav-bteam"
                aria-selected="false"
              >
                B-Tím
              </button>
              <button
                class="headerPage-tabs__btn"
                id="nav-women-tab"
                data-bs-toggle="tab"
                data-bs-target="#nav-women"
                type="button"
                role="tab"
                aria-controls="nav-women"
                aria-selected="false"
              >
                Ženy
              </button>
            </nav>

            <form action="">
              <select class="js-select" id="filterDate">
                <option selected>2025/2026</option>
                <option>2024/2025</option>
                <option>2023/2024</option>
                <option>2022/2023</option>
                <option>2024/2025</option>
                <option>2023/2024</option>
                <option>2022/2023</option>
                <option>2024/2025</option>
                <option>2023/2024</option>
                <option>2022/2023</option>
              </select>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  {% include "@components/table-section/table-section.twig" %}
</main>
{% endblock %}
